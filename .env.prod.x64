ASPNETCORE_ENVIRONMENT=Production
TARGETARCH=x64
BUILD_CONFIGURATION=Release
TELEGRAMBOT_PORT=443

# Email sender config (smtp|resend)
EmailSender__Provider=smtp
EmailSender__FromEmail=noreply@datagateapp.com
EmailSender__FromName=DataGate
EmailSender__ResendApiKey=
EmailSender__Host=smtp.example.com
EmailSender__Port=587
EmailSender__UseSsl=true
EmailSender__Username=smtp_user
EmailSender__Password=smtp_password